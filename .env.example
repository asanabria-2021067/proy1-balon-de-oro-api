NODE_ENV=development

# PostgreSQL
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=proy1_ballon_dor
DB_PORT=5433

# Supabase Transaction Pooler (required for Vercel serverless)
# Get from: Settings → Database → Connection string → Transaction mode
DATABASE_URL=postgresql://postgres.YOURPROJECT:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres

# JWT
JWT_SECRET=super-secret-key-change-in-production

# Cloudinary (unsigned preset - no API key/secret needed)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Server
PORT=3001
ALLOWED_ORIGIN=*

# PgAdmin (optional)
PGADMIN_EMAIL=admin@proy1.com
PGADMIN_PASSWORD=admin
