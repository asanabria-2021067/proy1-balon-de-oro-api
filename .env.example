# Supabase Transaction Pooler (required for Vercel serverless)
# Get from: Settings → Database → Connection string → Transaction mode
DATABASE_URL=postgresql://postgres.YOURPROJECT:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
ALLOWED_ORIGIN=*
PORT=3001
